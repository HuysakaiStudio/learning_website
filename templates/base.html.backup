<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>{% block title %}Ôn Thi THPTQG{% endblock %}</title>
  
  {% load static %}
  
  <!-- PWA Meta Tags -->
  <meta name="description" content="Ứng dụng ôn thi THPT Quốc Gia với đề thi, flashcard, và kiến thức chuyên sâu">
  <meta name="theme-color" content="#4285f4">
  <meta name="mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="apple-mobile-web-app-title" content="THPTQG">
  
  <!-- PWA Manifest -->
  <link rel="manifest" href="{% static 'manifest.json' %}">
  
  <!-- Favicon & App Icons -->
  <link rel="icon" type="image/png" sizes="32x32" href="{% static 'icons/icon-32x32.png' %}">
  <link rel="icon" type="image/png" sizes="16x16" href="{% static 'icons/icon-16x16.png' %}">
  <link rel="apple-touch-icon" sizes="180x180" href="{% static 'icons/apple-touch-icon.png' %}">
  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
  
  <!-- Design System - Psychology-Based UX -->
  <link rel="stylesheet" href="{% static 'css/design-system.css' %}">
  <link rel="stylesheet" href="{% static 'css/main.css' %}">
  
  <!-- Dark Mode -->
  <link rel="stylesheet" href="{% static 'css/dark-mode.css' %}">
  <link rel="stylesheet" href="{% static 'css/exam-dark-mode.css' %}">
  <link rel="stylesheet" href="{% static 'css/profile-achievements-dark.css' %}">
  
  <!-- PWA Mobile Optimizations -->
  <link rel="stylesheet" href="{% static 'css/pwa-mobile.css' %}">
  <link rel="stylesheet" href="{% static 'css/mobile-navbar.css' %}">
  
  <script src="{% static 'js/dark-mode.js' %}"></script>
  
  <!-- Page-specific CSS -->
  {% block extra_css %}{% endblock %}
  
  <!-- MathJax render công thức toán -->
  <script>
    MathJax = {
      tex: {
        inlineMath: [['$', '$'], ['\\(', '\\)']],
        displayMath: [['$$', '$$'], ['\\[', '\\]']],
        packages: { '[+]': ['ams'] }
      },
      options: {
        skipHtmlTags: ['script', 'noscript', 'style', 'textarea', 'code', 'pre'],
        ignoreHtmlClass: 'tex2jax_ignore',
        processHtmlClass: 'tex2jax_process'
      }
    };
  </script>
  <script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
  
  <style>
    /* Toast container */
    #toast-container {
      position: fixed;
      top: 20px;
      right: 20px;
      z-index: 9999;
    }

    .toast {
      background: #333;
      color: white;
      padding: 12px 20px;
      border-radius: 8px;
      margin-bottom: 10px;
      display: flex;
      align-items: center;
      gap: 10px;
      opacity: 0.9;
    }

    .toast.error {
      background: #ea4335;
    }

    .toast.success {
      background: #34a853;
    }
  </style>
</head>


<body>
  <div id="toast-container"></div>
  <!-- Top Row: Logo and Main Navigation -->
  <nav class="navbar navbar-expand-lg fixed-top shadow-sm bg-white" style="backdrop-filter: blur(10px); z-index: 1050;">
    <div class="container-fluid px-3">
      <a class="navbar-brand fw-bold text-primary" href="/" style="font-size: 1.1rem;">Ôn Thi THPTQG</a>
      <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
        aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
          <li class="nav-item"><a class="nav-link px-2" href="/">Trang chủ</a></li>
          <li class="nav-item dropdown mega-dropdown">
            <a class="nav-link dropdown-toggle px-2" href="#" id="knowledgeDropdown" role="button"
               data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true" tabindex="0">
              Kiến thức
            </a>
            <div class="mega-menu dropdown-menu shadow border-0" aria-labelledby="knowledgeDropdown">
              <div class="container">
                <div class="row">
                  <div class="col-md-3 mega-col">
                    <h6 class="mega-category">
                      <i class="bi bi-book me-2"></i>Môn học
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/kien-thuc/toan-hoc/">
                        <i class="bi bi-calculator me-2"></i>Toán học
                        <small class="d-block text-muted">Công thức, bài tập, đề thi</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/vat-ly/">
                        <i class="bi bi-lightning-charge me-2"></i>Vật lý
                        <small class="d-block text-muted">Hiện tượng, định luật, bài tập</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/hoa-hoc/">
                        <i class="bi bi-flask me-2"></i>Hóa học
                        <small class="d-block text-muted">Phản ứng, công thức, thí nghiệm</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/sinh-hoc/">
                        <i class="bi bi-dna me-2"></i>Sinh học
                        <small class="d-block text-muted">Di truyền, tiến hóa, sinh thái</small>
                      </a>
                    </div>
                  </div>
                  <div class="col-md-3 mega-col">
                    <h6 class="mega-category">
                      <i class="bi bi-journal me-2"></i>Bài viết
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/kien-thuc/bai-viet/moi-nhat/">
                        <i class="bi bi-calendar-check me-2"></i>Mới nhất
                        <small class="d-block text-muted">Bài viết cập nhật gần đây</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/bai-viet/pho-bien/">
                        <i class="bi bi-fire me-2"></i>Phổ biến
                        <small class="d-block text-muted">Bài viết được nhiều người xem</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/bai-viet/danh-cho-thpt/">
                        <i class="bi bi-mortarboard me-2"></i>Dành cho THPT
                        <small class="d-block text-muted">Kiến thức theo chương trình THPT</small>
                      </a>
                    </div>
                  </div>
                  <div class="col-md-3 mega-col">
                    <h6 class="mega-category">
                      <i class="bi bi-collection-play me-2"></i>Video
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/kien-thuc/video/gioi-thieu/">
                        <i class="bi bi-play-btn me-2"></i>Giới thiệu
                        <small class="d-block text-muted">Video giới thiệu các môn học</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/video/huong-dan/">
                        <i class="bi bi-tools me-2"></i>Hướng dẫn
                        <small class="d-block text-muted">Video hướng dẫn làm bài</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/video/thi-nghiem/">
                        <i class="bi bi-eyedropper me-2"></i>Thí nghiệm
                        <small class="d-block text-muted">Video thí nghiệm thực tế</small>
                      </a>
                    </div>
                  </div>
                  <div class="col-md-3 mega-col featured-col">
                    <h6 class="mega-category">
                      <i class="bi bi-lightbulb me-2"></i>Nổi bật
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/kien-thuc/flashcard/">
                        <i class="bi bi-card-front me-2"></i>Flashcard
                        <small class="d-block text-muted">Học nhanh, ghi nhớ hiệu quả</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/trac-nghiem/">
                        <i class="bi bi-ui-checks-grid me-2"></i>Trắc nghiệm
                        <small class="d-block text-muted">Luyện thi trực tuyến</small>
                      </a>
                      <a class="mega-link" href="/kien-thuc/tai-lieu/">
                        <i class="bi bi-folder me-2"></i>Tài liệu
                        <small class="d-block text-muted">Download tài liệu miễn phí</small>
                      </a>
                      <div class="mega-promo mt-3 p-3 bg-primary-subtle rounded">
                        <h6 class="text-primary mb-2">
                          <i class="bi bi-star me-2"></i>Ưu đãi đặc biệt
                        </h6>
                        <p class="text-sm mb-2">Tài khoản Premium giúp bạn truy cập tất cả nội dung</p>
                        <button class="btn btn-sm btn-primary">Dùng thử miễn phí</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li class="nav-item dropdown mega-dropdown">
            <a class="nav-link dropdown-toggle px-2" href="#" id="examDropdown" role="button"
               data-bs-toggle="dropdown" aria-expanded="false" aria-haspopup="true" tabindex="0">
              Đề thi
            </a>
            <div class="mega-menu dropdown-menu shadow border-0" aria-labelledby="examDropdown">
              <div class="container">
                <div class="row">
                  <div class="col-md-4 mega-col">
                    <h6 class="mega-category">
                      <i class="bi bi-file-earmark-text me-2"></i>Loại đề thi
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/de-thi/thpt-qg/">
                        <i class="bi bi-award me-2"></i>THPT Quốc Gia
                        <small class="d-block text-muted">Đề thi chính thức các năm</small>
                      </a>
                      <a class="mega-link" href="/de-thi/hoc-ky/">
                        <i class="bi bi-calendar-week me-2"></i>Học kỳ
                        <small class="d-block text-muted">Đề kiểm tra học kỳ các lớp</small>
                      </a>
                      <a class="mega-link" href="/de-thi/thu/">
                        <i class="bi bi-hourglass-split me-2"></i>Đề thử
                        <small class="d-block text-muted">Đề thi thử từ giáo viên</small>
                      </a>
                      <a class="mega-link" href="/de-thi/on-tap/">
                        <i class="bi bi-repeat me-2"></i>Ôn tập
                        <small class="d-block text-muted">Đề cương ôn tập theo chuyên đề</small>
                      </a>
                    </div>
                  </div>
                  <div class="col-md-4 mega-col">
                    <h6 class="mega-category">
                      <i class="bi bi-mortarboard me-2"></i>Theo khối
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/de-thi/khoi-a/">
                        <i class="bi bi-1-circle me-2"></i>Khối A
                        <small class="d-block text-muted">Toán, Lý, Hóa</small>
                      </a>
                      <a class="mega-link" href="/de-thi/khoi-a1/">
                        <i class="bi bi-2-circle me-2"></i>Khối A1
                        <small class="d-block text-muted">Toán, Lý, Anh</small>
                      </a>
                      <a class="mega-link" href="/de-thi/khoi-b/">
                        <i class="bi bi-3-circle me-2"></i>Khối B
                        <small class="d-block text-muted">Toán, Hóa, Sinh</small>
                      </a>
                      <a class="mega-link" href="/de-thi/khoi-c/">
                        <i class="bi bi-4-circle me-2"></i>Khối C
                        <small class="d-block text-muted">Văn, Sử, Địa</small>
                      </a>
                      <a class="mega-link" href="/de-thi/khoi-d/">
                        <i class="bi bi-5-circle me-2"></i>Khối D
                        <small class="d-block text-muted">Toán, Văn, Anh</small>
                      </a>
                    </div>
                  </div>
                  <div class="col-md-4 mega-col featured-col">
                    <h6 class="mega-category">
                      <i class="bi bi-graph-up me-2"></i>Thống kê
                    </h6>
                    <div class="mega-content">
                      <a class="mega-link" href="/de-thi/lich-su/">
                        <i class="bi bi-clock-history me-2"></i>Lịch sử làm bài
                        <small class="d-block text-muted">Theo dõi tiến độ học tập</small>
                      </a>
                      <a class="mega-link" href="/de-thi/phan-tich/">
                        <i class="bi bi-bar-chart-line me-2"></i>Phân tích kết quả
                        <small class="d-block text-muted">Hiểu rõ điểm mạnh/yếu</small>
                      </a>
                      <a class="mega-link" href="/de-thi/ca-nhan-hoa/">
                        <i class="bi bi-person-badge me-2"></i>Cá nhân hóa
                        <small class="d-block text-muted">Đề thi phù hợp năng lực</small>
                      </a>
                      <div class="mega-promo mt-3 p-3 bg-success-subtle rounded">
                        <h6 class="text-success mb-2">
                          <i class="bi bi-rocket-takeoff me-2"></i>Luyện đề hiệu quả
                        </h6>
                        <p class="text-sm mb-2">Luyện đề theo lộ trình cá nhân hóa</p>
                        <button class="btn btn-sm btn-success">Bắt đầu ngay</button>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </li>
          <li class="nav-item"><a class="nav-link px-2" href="/kien-thuc/flashcard/">Flashcard</a></li>
          <li class="nav-item"><a class="nav-link px-2" href="/leaderboard/">Xếp hạng</a></li>
          {% if user.is_authenticated %}
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle text-primary fw-bold px-2" href="#" id="createDropdown" role="button"
              data-bs-toggle="dropdown" aria-expanded="false">
              <i class="bi bi-plus-circle-fill"></i> Tạo mới
            </a>
            <ul class="dropdown-menu shadow border-0" aria-labelledby="createDropdown">
              <li><a class="dropdown-item" href="{% url 'kien_thuc:tao_bai_viet' %}">✍️ Bài viết mới</a></li>
              <li><a class="dropdown-item" href="{% url 'kien_thuc:tao_flashcard_set' %}">💡 Bộ Flashcard mới</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item fw-bold text-success" href="/studio/"><i class="bi bi-camera-video-fill me-2"></i>Studio</a></li>
              {% if user.is_staff %}
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item" href="/admin/de_thi/dethi/add/">⏱️ Đề thi mới (Admin)</a></li>
              {% endif %}
            </ul>
          </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  
  <!-- Bottom Row: Search, User Profile, Theme Toggle, and Notifications -->
  <nav class="navbar navbar-expand-lg bg-white shadow-sm" style="backdrop-filter: blur(10px); margin-top: 60px; z-index: 1040;">
    <div class="container-fluid px-3">
      <div class="d-flex w-100 align-items-center">
        <!-- Search -->
        <div class="flex-grow-1 me-3">
          <form action="/search/" method="get" class="d-flex">
            <input class="form-control form-control-sm" type="search" name="q" placeholder="Tìm kiếm..."
              aria-label="Search" style="min-width: 200px; flex-grow: 1;">
          </form>
        </div>
        
        <ul class="navbar-nav align-items-center">
          <!-- Theme Toggle -->
          <li class="nav-item me-2">
            <button id="theme-toggle" class="btn btn-sm btn-outline-secondary border-0" aria-label="Toggle dark mode">
              <i class="bi bi-moon-fill"></i>
            </button>
          </li>
          
          <!-- Notifications -->
          {% if user.is_authenticated %}
          <li class="nav-item me-2">
            {% include 'notifications/widget.html' %}
          </li>
          {% endif %}
          
          <!-- User Menu -->
          {% if user.is_authenticated %}
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center px-2" href="#" id="userDropdown" role="button"
              data-bs-toggle="dropdown" aria-expanded="false">
              {% if user.profile.avatar %}
              <img src="{{ user.profile.avatar.url }}" alt="Avatar" class="rounded-circle me-2"
                style="width: 32px; height: 32px; object-fit: cover;">
              {% else %}
              <i class="bi bi-person-circle me-2" style="font-size: 1.5rem;"></i>
              {% endif %}
              <span class="hide-mobile">{{ user.username }}</span>
            </a>
            <ul class="dropdown-menu dropdown-menu-end shadow border-0" aria-labelledby="userDropdown">
              <li><a class="dropdown-item" href="{% url 'nguoi_dung:profile' %}"><i class="bi bi-person me-2"></i>Hồ sơ</a></li>
              <li><a class="dropdown-item" href="/de-thi/lich-su/"><i class="bi bi-clock-history me-2"></i>Lịch sử</a></li>
              <li><a class="dropdown-item" href="/leaderboard/achievements/"><i class="bi bi-trophy me-2"></i>Thành tích</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="{% url 'nguoi_dung:dang_xuat' %}"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
            </ul>
          </li>
          {% else %}
          <li class="nav-item">
            <a class="btn btn-sm btn-primary px-3" href="{% url 'nguoi_dung:dang_nhap' %}">Đăng nhập</a>
          </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  <main style="margin-top: 70px; min-height: calc(100vh - 140px);">
    {% block content %}{% endblock %}
  </main>

  <footer class="bg-light py-4 mt-5">
    <div class="container text-center">
      <p class="mb-2">&copy; 2024 Ôn Thi THPTQG. All rights reserved.</p>
      <p class="text-muted small">
        <a href="/about/" class="text-decoration-none">Về chúng tôi</a> |
        <a href="/privacy/" class="text-decoration-none">Chính sách</a> |
        <a href="/contact/" class="text-decoration-none">Liên hệ</a>
      </p>
    </div>
  </footer>

  <!-- Bootstrap JS -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  
  <!-- Main JS -->
  <script src="{% static 'js/main.js' %}"></script>
  <script src="{% static 'js/psychology-ux.js' %}"></script>
  
  <!-- PWA JS -->
  <script src="{% static 'js/pwa.js' %}"></script>
  <script src="{% static 'js/mobile-navbar.js' %}"></script>
  
  <!-- Page-specific JS -->
  {% block extra_js %}{% endblock %}
</body>
</html>
