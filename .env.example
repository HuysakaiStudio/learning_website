# File .env mẫu - Copy thành .env và điền thông tin thực
# KHÔNG commit file .env thật vào Git!

# Django Secret Key - Tạo mới tại: https://djecrety.ir/
SECRET_KEY=django-insecure-your-secret-key-here-change-this

# Debug mode - Set False khi deploy production
DEBUG=True

# Allowed hosts - Thêm domain của bạn khi deploy
# Ví dụ: ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# Database URL (optional) - Dùng khi deploy với PostgreSQL
# Ví dụ: DATABASE_URL=postgresql://user:password@host:5432/dbname
# DATABASE_URL=
